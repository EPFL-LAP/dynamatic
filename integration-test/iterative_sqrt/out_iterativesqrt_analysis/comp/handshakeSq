    %trueResult_4 %(9), %falseResult_5 = cond_br %18, %14 {handshake.bb = 2 : ui32, handshake.name = "cond_br38"} : <i1>, <i1>  #true: arg1BB2  false: BB6
    %trueResult_6 %(arg0) , %falseResult_7 = cond_br %18, %7 {handshake.bb = 2 : ui32, handshake.name = "cond_br39"} : <i1>, <i32>       #true: (n =arg0) BB2  false: BB6
