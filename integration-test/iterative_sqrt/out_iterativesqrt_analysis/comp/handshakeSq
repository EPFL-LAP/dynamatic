    %17 %(6)= cmpi sle, %15, %16 {handshake.bb = 1 : ui32, handshake.name = "cmpi0"} : <i32>
    %18 %(7) = andi %17, %12 {handshake.bb = 1 : ui32, handshake.name = "andi0"} : <i1>  #c1
