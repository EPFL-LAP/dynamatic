    %11 = mux %(gamma12) %28 [%34, %16] {ftd.phi, handshake.bb = 1 : ui32, handshake.name = "mux6"} : <i1>, [<i32>, <i32>] to <i32>
    %12 %(5) = mux %(mu5) %6 [%3, %25] {ftd.phi, handshake.bb = 1 : ui32, handshake.name = "mux7"} : <i1>, [<i1>, <i1>] to <i1>  # arg4bb1
