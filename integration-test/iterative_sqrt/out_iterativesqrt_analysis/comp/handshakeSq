    %25 %(16) = cmpi ne, %23, %trueResult_6 {handshake.bb = 2 : ui32, handshake.name = "cmpi2"} : <i32>  #c2
    %26 %(17) = andi %25, %trueResult_4 {handshake.bb = 2 : ui32, handshake.name = "andi1"} : <i1>
    %27 %(18) = select %24[%22, %trueResult_2] {handshake.bb = 2 : ui32, handshake.name = "select0"} : <i1>, <i32>
    %28 %(19) = cmpi slt, %23, %trueResult_6 {handshake.bb = 2 : ui32, handshake.name = "cmpi3"} : <i32>  #c3
    %trueResult_12, %falseResult_13 = cond_br %28, %22 {handshake.bb = 4 : ui32, handshake.name = "cond_br42"} : <i1>, <i32> #cbr BB3 , send mid
    %29 = source {handshake.bb = 4 : ui32, handshake.name = "source7"} : <>
    %30 = constant %29 {handshake.bb = 4 : ui32, handshake.name = "constant5", value = 1 : i32} : <>, <i32>
    %31 %(20) = addi %trueResult_12, %30 {handshake.bb = 4 : ui32, handshake.name = "addi1"} : <i32>
    %32 = source {handshake.bb = 5 : ui32, handshake.name = "source8"} : <>
    %33 = constant %32 {handshake.bb = 5 : ui32, handshake.name = "constant6", value = -1 : i32} : <>, <i32>
    %34 %(21) = addi %falseResult_13, %33 {handshake.bb = 5 : ui32, handshake.name = "addi2"} : <i32>
    %35 = select %falseResult_5[%falseResult_9, %falseResult_3] {handshake.bb = 6 : ui32, handshake.name = "select1"} : <i1>, <i32>
    end {handshake.bb = 6 : ui32, handshake.name = "end0"} %35, %arg1 : <i32>, <>
  }
}

