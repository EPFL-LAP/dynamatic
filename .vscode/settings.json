{
  "editor.detectIndentation": false,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.useTabStops": true,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
  "files.associations": {
    "*.inc": "cpp",
    "vector": "c",
    "loop_multiply.h": "c",
    "integration.h": "c",
    "random": "c",
    "type_traits": "cpp",
    "__bit_reference": "cpp",
    "bitset": "cpp",
    "deque": "cpp",
    "__memory": "cpp",
    "limits": "cpp",
    "ratio": "cpp",
    "scoped_allocator": "cpp",
    "tuple": "cpp",
    "array": "cpp",
    "functional": "cpp",
    "utility": "cpp",
    "variant": "cpp",
    "__split_buffer": "cpp",
    "forward_list": "cpp",
    "list": "cpp",
    "queue": "cpp",
    "span": "cpp",
    "string": "cpp",
    "string_view": "cpp",
    "ranges": "cpp"
  },
  "cmake.configureSettings": {
    "MLIR_DIR": "${workspaceFolder}/polygeist/llvm-project/build/lib/cmake/mlir",
    "LLVM_DIR": "${workspaceFolder}/polygeist/llvm-project/build/lib/cmake/llvm",
    "CLANG_DIR": "${workspaceFolder}/polygeist/llvm-project/build/lib/cmake/clang",
    "CMAKE_C_COMPILER": "clang",
    "CMAKE_CXX_COMPILER": "clang++",
    "LLVM_ENABLE_LLD": "ON",
    "LLVM_TARGETS_TO_BUILD": "host",
    "CMAKE_BUILD_TYPE": "Debug",
    "CMAKE_EXPORT_COMPILE_COMMAND": "ON"
  },
  "C_Cpp.errorSquiggles": "disabled",
  "C_Cpp.codeAnalysis.clangTidy.checks.disabled": [
    "clang-diagnostic-error"
  ]
}
